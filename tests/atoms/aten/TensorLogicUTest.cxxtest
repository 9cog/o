	// ============================================================
	// Integration Tests with New Features
	// ============================================================

	void test_sparse_relation_reasoning()
	{
		// Create a sparse parent relation for a large family tree
		SparseTensor parent({10, 10});
		parent.set({0, 1}, 1.0);  // Person 0 is parent of 1
		parent.set({0, 2}, 1.0);  // Person 0 is parent of 2
		parent.set({1, 3}, 1.0);  // Person 1 is parent of 3
		parent.set({2, 4}, 1.0);  // Person 2 is parent of 4

		ATenValuePtr dense_parent = parent.to_dense();

		TensorProgram prog("sparse_family", ReasoningMode::BOOLEAN);
		prog.add_fact("parent", dense_parent);
		prog.add_equation("gp", "grandparent", {"parent", "parent"},
		                  "ij,jk->ik", Nonlinearity::THRESHOLD);

		prog.forward();

		ATenValuePtr gp = prog.get_derived("grandparent");
		TS_ASSERT(gp != nullptr);

		// Convert back to sparse for verification
		SparseTensorPtr sparse_gp = SparseTensor::from_dense(gp);
		TS_ASSERT(sparse_gp != nullptr);

		// grandparent[0,3] = 1 (through 1)
		// grandparent[0,4] = 1 (through 2)
		TS_ASSERT_DELTA(sparse_gp->get({0, 3}), 1.0, 1e-10);
		TS_ASSERT_DELTA(sparse_gp->get({0, 4}), 1.0, 1e-10);
	}

	void test_training_with_adam()
	{
		TensorProgram prog("training");
		auto adam = std::make_shared<AdamOptimizer>(0.01);
		prog.set_optimizer(adam);

		// Set up a simple learning scenario
		ATenValuePtr input = createATenFromVector({1.0, 0.0, 0.0, 1.0}, {2, 2});
		ATenValuePtr target = createATenFromVector({0.0, 1.0, 1.0, 0.0}, {2, 2});

		prog.add_fact("input", input);
		prog.add_equation("transform", "output", {"input"}, "ij->ij");

		// Training should run without error
		double loss = prog.train({{"input", input}}, {{"output", target}}, 10);
		TS_ASSERT(loss >= 0.0);
	}

	void test_optimizer_learning_convergence()
	{
		// Test that Adam converges on a simple problem
		AdamOptimizer adam(0.1);
		ATenValuePtr param = createATenFromVector({5.0}, {1});

		// Try to reach 0.0
		for (int i = 0; i < 100; i++)
		{
			auto vec = param->to_vector();
			ATenValuePtr grad = createATenFromVector({vec[0]}, {1});  // grad = param
			param = adam.update(param, grad);
		}

		auto final = param->to_vector();
		TS_ASSERT(std::abs(final[0]) < 1.0);  // Should have converged closer to 0
	}

	void test_sparse_large_tensor()
	{
		// Test with a larger sparse tensor
		SparseTensor large({100, 100});

		// Add diagonal entries
		for (int i = 0; i < 100; i++)
		{
			large.set({(int64_t)i, (int64_t)i}, 1.0);
		}

		TS_ASSERT_EQUALS(large.nnz(), (size_t)100);
		TS_ASSERT_DELTA(large.sparsity(), 0.01, 1e-10);

		// Convert to dense and back
		ATenValuePtr dense = large.to_dense();
		SparseTensorPtr back = SparseTensor::from_dense(dense);

		TS_ASSERT_EQUALS(back->nnz(), (size_t)100);
	}

	void test_gradient_accumulation()
	{
		// Test that gradients accumulate properly
		GradientTape tape;
		tape.start();

		ATenValuePtr x = createATenFromVector({1.0}, {1});
		ATenValuePtr y1 = createATenFromVector({2.0}, {1});
		ATenValuePtr y2 = createATenFromVector({3.0}, {1});
		ATenValuePtr z = createATenFromVector({5.0}, {1});

		// x -> y1 and x -> y2, both contribute to gradient
		tape.record("op1", {x}, y1, [](const ATenValuePtr& grad) {
			return std::vector<ATenValuePtr>{grad};
		});
		tape.record("op2", {x}, y2, [](const ATenValuePtr& grad) {
			return std::vector<ATenValuePtr>{grad};
		});
		tape.record("add", {y1, y2}, z, [](const ATenValuePtr& grad) {
			return std::vector<ATenValuePtr>{grad, grad};
		});

		tape.stop();

		ATenValuePtr grad_z = createATenFromVector({1.0}, {1});
		tape.backward(z, grad_z);

		ATenValuePtr grad_x = tape.gradient(x);
		TS_ASSERT(grad_x != nullptr);
		// Gradient should be 2.0 (accumulated from both paths)
		TS_ASSERT_DELTA(grad_x->to_vector()[0], 2.0, 1e-10);
	}
};
